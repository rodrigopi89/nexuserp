rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /companies/{companyId}
    // Fields: name, taxId, ownerUid, plan, modules, createdAt
    //
    // Collection: /users/{userId}
    // Fields: displayName, email, role, companyId, permissions
    //
    // Collection: /companies/{companyId}/products/{productId}
    // Fields: name, sku, price, stock, companyId
    //
    // Collection: /companies/{companyId}/sales/{saleId}
    // Fields: items, total, status, companyId, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCompanyOwner(companyId) {
      return isAuthenticated() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid == request.auth.uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasCompanyAccess(companyId) {
      return isAuthenticated() && (isCompanyOwner(companyId) || getUserData().companyId == companyId);
    }

    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        (request.auth.token.email == "rodrigosrn92@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'admin';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /companies/{companyId} {
      allow read: if hasCompanyAccess(companyId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isCompanyOwner(companyId) || isAdmin();

      match /products/{productId} {
        allow read: if hasCompanyAccess(companyId);
        allow write: if hasCompanyAccess(companyId);
      }

      match /sales/{saleId} {
        allow read: if hasCompanyAccess(companyId);
        allow write: if hasCompanyAccess(companyId);
      }

      match /customers/{customerId} {
        allow read: if hasCompanyAccess(companyId);
        allow write: if hasCompanyAccess(companyId);
      }

      match /financial/{transactionId} {
        allow read: if hasCompanyAccess(companyId);
        allow write: if hasCompanyAccess(companyId);
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
